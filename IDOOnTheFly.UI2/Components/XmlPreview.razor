@using Microsoft.JSInterop

<div>
    @if (string.IsNullOrEmpty(Xml))
    {
        <p class="text-muted">XML will appear here after you click Generate.</p>
    }
    else
    {
        <pre class="p-3 rounded" style="background:#1e1e1e;color:#d4d4d4;font-size:13px;max-height:500px;overflow:auto;"><code>@Xml</code></pre>
    }
</div>

@code {
    [Parameter] public string Xml { get; set; } = string.Empty;
}
